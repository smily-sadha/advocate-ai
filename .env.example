# Advocate AI - Environment Configuration
# Copy this to .env and edit values

# ── LLM Settings ──────────────────────────────────────────
# Options: llama3, mistral
LLM_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# ── Embedding Model ────────────────────────────────────────
# BGE is recommended for Indian legal text
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5

# ── ChromaDB ───────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=advocate_legal_docs

# ── RAG Settings ───────────────────────────────────────────
TOP_K_RESULTS=5
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Speech Settings ────────────────────────────────────────
WHISPER_MODEL=base          # Options: tiny, base, small, medium, large
TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC
AUDIO_UPLOAD_DIR=./data/audio_uploads
AUDIO_OUTPUT_DIR=./data/audio_outputs

# ── API Settings ───────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
MAX_TOKENS=2048
TEMPERATURE=0.1             # Low temp = more deterministic legal answers

# ── Session Settings ───────────────────────────────────────
MAX_HISTORY_TURNS=5         # Conversation memory turns

# ── App Settings ───────────────────────────────────────────
APP_NAME=Advocate AI
LOG_LEVEL=INFO
